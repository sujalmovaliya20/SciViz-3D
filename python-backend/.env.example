# Python Backend Environment Variables

# The API Key for Anthropic (Required for Simulation AI)
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Origins allowed to access the Python API (CORS)
# For localhost: http://localhost:5173
# For Production: Your Render Web Service URL
CORS_ORIGINS=http://localhost:5173

# Port for the Python service (Default: 8000)
PORT=8000

# Environment Mode (development or production)
NODE_ENV=development
